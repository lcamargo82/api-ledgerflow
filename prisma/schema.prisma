generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String
  passwordHash         String
  active               Boolean               @default(true)
  tokenVersion         Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  createdAccounts      Account[]             @relation("AccountCreatedBy")
  updatedAccounts      Account[]             @relation("AccountUpdatedBy")
  createdCategories    Category[]            @relation("CategoryCreatedBy")
  updatedCategories    Category[]            @relation("CategoryUpdatedBy")
  createdTransactions  Transaction[]         @relation("TransactionCreatedBy")
  acceptedInvitations  WorkspaceInvitation[] @relation("WorkspaceInvitationAcceptedBy")
  invitedMemberships   WorkspaceMember[]     @relation("WorkspaceMemberInvitedBy")
  sentInvitations      WorkspaceInvitation[] @relation("WorkspaceInvitationInvitedBy")
  updatedTransactions  Transaction[]         @relation("TransactionUpdatedBy")
  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  passwordResetTokens  PasswordResetToken[]
  refreshTokens        RefreshToken[]
  workspaceMemberships WorkspaceMember[]

  @@map("users")
}

model Workspace {
  id           String                @id @default(uuid())
  name         String
  type         WorkspaceType
  ownerUserId  String
  currency     String                @default("BRL")
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  accounts     Account[]
  categories   Category[]
  members      WorkspaceMember[]
  owner        User                  @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  transactions Transaction[]
  invitations  WorkspaceInvitation[]

  @@index([ownerUserId])
  @@index([type])
  @@map("workspaces")
}

model WorkspaceMember {
  id              String        @id @default(uuid())
  workspaceId     String
  userId          String
  role            WorkspaceRole
  invitedByUserId String?
  joinedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy       User?         @relation("WorkspaceMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
  @@map("workspace_members")
}

model Category {
  id              String        @id @default(uuid())
  workspaceId     String
  name            String
  type            CategoryType
  color           String        @default("#64748B")
  icon            String        @default("tag")
  isSystemDefault Boolean       @default(false)
  active          Boolean       @default(true)
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       User          @relation("CategoryCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  transactions    Transaction[]
  updatedBy       User?         @relation("CategoryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name, type])
  @@index([workspaceId, type])
  @@map("categories")
}

model Account {
  id                      String        @id @default(uuid())
  workspaceId             String
  institutionId           String?
  name                    String
  description             String?
  type                    AccountType
  color                   String
  icon                    String
  includeInTotal          Boolean       @default(true)
  active                  Boolean       @default(true)
  createdByUserId         String
  updatedByUserId         String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  createdBy               User          @relation("AccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  transactions            Transaction[]
  destinationTransactions Transaction[] @relation("TransactionDestinationAccount")
  updatedBy               User?         @relation("AccountUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  workspace               Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, active])
  @@map("accounts")
}

model Transaction {
  id                   String            @id @default(uuid())
  workspaceId          String
  accountId            String
  destinationAccountId String?
  categoryId           String?
  type                 TransactionType
  origin               TransactionOrigin @default(MANUAL)
  amount               Decimal           @db.Decimal(14, 2)
  description          String
  occurredAt           DateTime
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  account              Account           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  destinationAccount   Account?          @relation("TransactionDestinationAccount", fields: [destinationAccountId], references: [id], onDelete: Restrict)
  category             Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy            User              @relation("TransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy            User?             @relation("TransactionUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  workspace            Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@index([accountId])
  @@index([destinationAccountId])
  @@index([categoryId])
  @@map("transactions")
}

model WorkspaceInvitation {
  id               String                    @id @default(uuid())
  workspaceId      String
  email            String
  role             WorkspaceRole
  status           WorkspaceInvitationStatus @default(PENDING)
  tokenHash        String                    @unique
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  acceptedBy       User?                     @relation("WorkspaceInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  invitedBy        User                      @relation("WorkspaceInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([email])
  @@map("workspace_invitations")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

enum WorkspaceType {
  PERSONAL
  BUSINESS
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum CategoryType {
  INCOME
  EXPENSE
  ADJUSTMENT
}

enum AccountType {
  CHECKING
  SAVINGS
  WALLET
  INVESTMENT
  BENEFITS
  CREDIT_CARD
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionOrigin {
  MANUAL
  INITIAL_BALANCE
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
  EXPIRED
}
